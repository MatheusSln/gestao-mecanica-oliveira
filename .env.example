# =====================================================
# CONFIGURAÇÃO DO FIREBASE - MECÂNICA OLIVEIRA
# =====================================================
# 1. Acesse https://console.firebase.google.com
# 2. Crie um projeto chamado "mecanica-oliveira"
# 3. Clique em "+ Adicionar app" → escolha Web (</>)
# 4. Copie os valores do firebaseConfig e cole abaixo
# 5. Renomeie este arquivo para .env.local
# =====================================================

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=mecanica-oliveira.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=mecanica-oliveira
VITE_FIREBASE_STORAGE_BUCKET=mecanica-oliveira.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

